# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB
# Local: mongodb://127.0.0.1:27017/resume_tailor
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/resume_tailor
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/resume_tailor
# LLM provider used for resume/JD parsing + tailored bullet generation.
# "anthropic" (Claude) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings provider used for match scoring.
# "local"  -> free, dependency-free hashed bag-of-words vectors, no API key needed
# "openai" -> real embeddings via OpenAI's API (requires OPENAI_API_KEY above), more accurate
EMBEDDINGS_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_DIMS=256

# Upload limits
MAX_UPLOAD_MB=8
